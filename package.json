{
  "name": "openclaw-installer",
  "version": "1.0.0",
  "description": "OpenClaw 一键安装程序 — 教培AI实战营专用",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "node scripts/test.js",
    "test:e2e": "node scripts/e2e-test.js",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:all": "electron-builder --win --mac"
  },
  "dependencies": {
    "sudo-prompt": "^9.2.1"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  }
}
